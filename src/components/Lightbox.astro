<div id="lightbox" class="lightbox" aria-modal="true" role="dialog" aria-hidden="true">
  <div class="lightbox-backdrop" data-close></div>
  <div class="lightbox-content" role="document">
    <button class="lb-btn lb-close" id="lb-close" aria-label="Close" data-close>&times;</button>
    <button class="lb-btn lb-prev" id="lb-prev" aria-label="Previous image">&lsaquo;</button>
    <img id="lb-image" alt="Project screenshot" />
    <button class="lb-btn lb-next" id="lb-next" aria-label="Next image">&rsaquo;</button>
  </div>
</div>
